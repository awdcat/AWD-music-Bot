{
  "name": "discord-mod-music-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Discord moderation and YouTube music bot with slash commands.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "deploy": "node src/deploy-commands.js",
    "invite": "node src/print-invite.js",
    "panel": "node src/panel.js",
    "panel:pm2": "pm2 start src/panel.js --name hzx-panel",
    "panel:stop": "pm2 stop hzx-panel",
    "start": "node src/index.js",
    "dev": "node --watch src/index.js"
  },
  "dependencies": {
    "@discord-player/extractor": "^7.2.0",
    "@snazzah/davey": "^0.1.9",
    "discord-player": "^7.2.0",
    "discord-player-youtubei": "3.0.0-beta.4",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.2.0",
    "youtube-dl-exec": "^3.1.4"
  }
}
